{
    "rewrites": [
        {
            "source": "/v1/chat/completions",
            "destination": "/api/ai/chat"
        },
        {
            "source": "/v1/completions",
            "destination": "/api/ai/chat"
        },
        {
            "source": "/v1/models",
            "destination": "/api/v1/models"
        },
        {
            "source": "/v1/metrics",
            "destination": "/api/v1/metrics"
        },
        {
            "source": "/v1/responses",
            "destination": "/api/v1/responses"
        },
        {
            "source": "/v1/agents",
            "destination": "/api/v1/agents"
        },
        {
            "source": "/v1/agents/:path*",
            "destination": "/api/v1/agents/:path*"
        },
        {
            "source": "/v1/agent/actions/poll",
            "destination": "/api/v1/agent/actions/poll"
        },
        {
            "source": "/v1/billing/:path*",
            "destination": "/api/v1/billing/:path*"
        },
        {
            "source": "/v1/telemetry/scan",
            "destination": "/api/v1/telemetry/scan"
        },
        {
            "source": "/v1/telemetry/web",
            "destination": "/api/v1/telemetry/web"
        },
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "design.cencori.com"
                }
            ],
            "destination": "/design/:path*"
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "host",
                    "value": "design.cencori.com"
                }
            ],
            "destination": "/design"
        },
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "pitch.cencori.com"
                }
            ],
            "destination": "/pitch/:path*"
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "host",
                    "value": "pitch.cencori.com"
                }
            ],
            "destination": "/pitch"
        }
    ],
    "redirects": [
        {
            "source": "/discord",
            "destination": "https://discord.gg/j3eAV5WzCa",
            "permanent": false
        },
        {
            "source": "/old-path",
            "destination": "/new-path",
            "permanent": true
        },
        {
            "source": "/temporary-service",
            "destination": "/maintenance",
            "permanent": false
        },
        {
            "source": "/old-blog/:slug",
            "destination": "/new-blog/:slug",
            "permanent": true
        }
    ],
    "crons": [
        {
            "path": "/api/cron/reset-usage",
            "schedule": "0 0 1 * *"
        }
    ]
}
