# Cencori — environment variables
# Copy to `.env.local` and fill in values:  cp .env.example .env.local
#
# Tiers:
#   [REQUIRED]  app will not boot / core auth & gateway break without these
#   [PROVIDER]  need at least one AI provider key to make gateway calls
#   [OPTIONAL]  feature-specific; safe to leave blank for basic local dev
#
# Auto-provided by the platform (do NOT set): NODE_ENV, VERCEL_ENV, VERCEL_URL

# ───────────────────────────────────────────────────────────────
# Supabase  [REQUIRED — first three are needed for the app to start]
# ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=   # browser + SSR clients + middleware
SUPABASE_SERVICE_ROLE_KEY=                       # admin client + middleware access checks
NEXT_PUBLIC_SUPABASE_ANON_KEY=                   # used by some /api/v1/* routes
SUPABASE_JWT_SECRET=                             # optional; JWT verification

# ───────────────────────────────────────────────────────────────
# Encryption  [REQUIRED for BYOK / custom provider keys & stored secrets]
# ───────────────────────────────────────────────────────────────
ENCRYPTION_SECRET=                               # 32+ char secret

# ───────────────────────────────────────────────────────────────
# AI providers  [PROVIDER — need >= 1; Gemini is the free-tier default]
# ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=                                  # aliases: GOOGLE_AI_API_KEY, GOOGLE_GENERATIVE_AI_API_KEY (first set wins)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=                                    # also used by Scan AI auto-fix
CEREBRAS_API_KEY=                                # Scan AI auto-fix (primary reasoning model)
COHERE_API_KEY=
ZAI_API_KEY=                                   # Z.AI (GLM models)

# ───────────────────────────────────────────────────────────────
# Cache + rate limiting (Upstash Redis)  [OPTIONAL — both fail open if absent]
# ───────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_FAIL_OPEN=true
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_EXPECTED_DIMENSIONS=768

# ───────────────────────────────────────────────────────────────
# App URLs  [OPTIONAL — default to localhost in dev]
# ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_SCAN_URL=
NEXT_PUBLIC_SCAN_APP_URL=
NEXT_PUBLIC_EMAIL_DOMAIN=cencori.com
EMAIL_DOMAIN=cencori.com

# ───────────────────────────────────────────────────────────────
# Billing: Polar (subscriptions + credit top-ups)  [OPTIONAL]
# ───────────────────────────────────────────────────────────────
POLAR_API_KEY=
POLAR_ORGANIZATION_ID=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_PRO_MONTHLY=
POLAR_PRODUCT_PRO_ANNUAL=
POLAR_PRODUCT_TEAM_MONTHLY=
POLAR_PRODUCT_TEAM_ANNUAL=
POLAR_PRODUCT_CREDITS_STARTER=
POLAR_PRODUCT_CREDITS_GROWTH=
POLAR_PRODUCT_CREDITS_SCALE=
POLAR_PRODUCT_SCAN_MONTHLY=
POLAR_PRODUCT_SCAN_TEAM_MONTHLY=

# ───────────────────────────────────────────────────────────────
# Billing: Stripe Connect (end-user / reseller billing)  [OPTIONAL]
# ───────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_CONNECT_WEBHOOK_SECRET=

# ───────────────────────────────────────────────────────────────
# GitHub App (Scan product)  [OPTIONAL]
# ───────────────────────────────────────────────────────────────
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_STATE_SECRET=
GITHUB_WEBHOOK_SECRET=
NEXT_PUBLIC_GITHUB_APP_ID=
NEXT_PUBLIC_GITHUB_APP_SLUG=

# ───────────────────────────────────────────────────────────────
# Email (Resend)  [OPTIONAL]
# ───────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_REPLY_TO_EMAIL=
RESEND_WELCOME_FROM_EMAIL=
RESEND_WELCOME_REPLY_TO_EMAIL=
RESEND_NEWSLETTER_FROM_EMAIL=
RESEND_CONTACT_FROM_EMAIL=
RESEND_BUDGET_FROM_EMAIL=
RESEND_ORG_INVITE_FROM_EMAIL=
RESEND_ORG_INVITE_REPLY_TO_EMAIL=
RESEND_ADMIN_INVITE_FROM_EMAIL=
RESEND_ADMIN_INVITE_REPLY_TO_EMAIL=
RESEND_TEAM_FROM_EMAIL=

# ───────────────────────────────────────────────────────────────
# Analytics (PostHog)  [OPTIONAL]
# ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ───────────────────────────────────────────────────────────────
# Vercel edge integration (OAuth)  [OPTIONAL]
# ───────────────────────────────────────────────────────────────
VERCEL_INTEGRATION_CLIENT_ID=
VERCEL_INTEGRATION_CLIENT_SECRET=
VERCEL_INTEGRATION_SLUG=
VERCEL_INTEGRATION_INSTALL_URL=
VERCEL_INTEGRATION_REDIRECT_URI=
VERCEL_INTEGRATION_PUBLIC_BASE_URL=
VERCEL_INTEGRATION_STATE_SECRET=

# ───────────────────────────────────────────────────────────────
# RagMetrics (RAG quality eval)  [OPTIONAL]
# ───────────────────────────────────────────────────────────────
RAGMETRICS_API_URL=
RAGMETRICS_RESULTS_URL=

# ───────────────────────────────────────────────────────────────
# Cron + internal secrets  [OPTIONAL]
# ───────────────────────────────────────────────────────────────
CRON_SECRET=                                     # Bearer token guarding /api/cron/*
WEB_LOG_INGEST_SECRET=
USER_UNSUBSCRIBE_SECRET=
WAITLIST_WEBHOOK_URL=
SCAN_STRICT_ENFORCEMENT=

# ───────────────────────────────────────────────────────────────
# Internal admin gating  [OPTIONAL]
# ───────────────────────────────────────────────────────────────
INTERNAL_FOUNDER_EMAILS=
ALLOW_ALL_INTERNAL_IN_DEV=                        # set true to bypass @cencori.com check locally
NEXTAUTH_SECRET=                                  # legacy; app primarily uses Supabase auth

# ───────────────────────────────────────────────────────────────
# Self-referential (Scan AI auto-fix calls the gateway)  [OPTIONAL]
# ───────────────────────────────────────────────────────────────
CENCORI_API_URL=
CENCORI_API_KEY=
